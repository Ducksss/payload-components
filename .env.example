# Public canonical URL used for metadata, docs links, and LLM text surfaces.
# The Fumadocs site builds without a Payload secret or database.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: only needed when running the external Payload smoke test or testing
# generated target projects that need Payload environment variables.
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/payload_components
PAYLOAD_SECRET=payload-kit-local-secret
PREVIEW_SECRET=payload-kit-local-preview-secret
CRON_SECRET=payload-kit-local-cron-secret
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
