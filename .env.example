# Optional public-site overrides for the docs app.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_CONTENT_BRANCH=dev

# Product analytics (PostHog). Public project key (phc_...) — safe to expose in
# the client bundle. The production domain uses the Tin-managed key by default;
# set this only for local testing or a different PostHog project. Events are sent
# only from the production site or localhost with a configured key.
# Host defaults to the US region; set the EU host if your project lives there.
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
