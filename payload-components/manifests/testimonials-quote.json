{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "testimonials-quote",
  "version": "0.1.0",
  "title": "Testimonials Quote",
  "description": "A single featured customer testimonial: a quote with a left accent bar, author, optional role, and avatar.",
  "registryItemName": "testimonials-quote",
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "files": [
    "src/blocks/shared/testimonialFields.ts",
    "src/blocks/TestimonialsQuote/config.ts",
    "src/blocks/TestimonialsQuote/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "TestimonialsQuoteBlock",
      "importPath": "@/blocks/TestimonialsQuote/Component",
      "blockSlug": "testimonialsQuote"
    },
    {
      "kind": "pagesLayout",
      "importName": "TestimonialsQuote",
      "importPath": "../../blocks/TestimonialsQuote/config",
      "blockName": "TestimonialsQuote"
    }
  ],
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Single featured testimonial: a quote with a left accent bar, author, optional role and avatar."
  },
  "sampleContent": {
    "blockType": "testimonialsQuote",
    "quote": "Using Acme has been like unlocking a design superpower — the perfect fusion of simplicity and versatility.",
    "author": "Théa Marchetti",
    "role": "VP Engineering, Northwind"
  },
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  }
}
