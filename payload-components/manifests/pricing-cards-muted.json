{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "pricing-cards-muted",
  "version": "0.1.0",
  "title": "Pricing Cards Muted",
  "description": "The three-up pricing table on soft muted card surfaces with a highlighted featured plan, installed as a wired Payload block.",
  "registryItemName": "pricing-cards-muted",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/pricingFields.ts",
    "src/blocks/PricingCardsMuted/config.ts",
    "src/blocks/PricingCardsMuted/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "PricingCardsMutedBlock",
      "importPath": "@/blocks/PricingCardsMuted/Component",
      "blockSlug": "pricingCardsMuted"
    },
    {
      "kind": "pagesLayout",
      "importName": "PricingCardsMuted",
      "importPath": "../../blocks/PricingCardsMuted/config",
      "blockName": "PricingCardsMuted"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Three plan cards on muted surfaces with the featured plan highlighted in emerald."
  },
  "sampleContent": {
    "blockType": "pricingCardsMuted",
    "eyebrow": "Pricing",
    "title": "Pricing that scales with your team.",
    "description": "Start free and upgrade as you grow — every plan ships with the core platform and support.",
    "plans": [
      {
        "name": "Free",
        "price": "$0",
        "period": "/ mo",
        "description": "Per editor",
        "featured": false,
        "features": [
          { "feature": "Basic analytics dashboard" },
          { "feature": "5GB cloud storage" },
          { "feature": "Email and chat support" }
        ],
        "links": [
          {
            "link": {
              "type": "custom",
              "newTab": false,
              "url": "/admin",
              "label": "Get started",
              "appearance": "outline"
            }
          }
        ]
      },
      {
        "name": "Pro",
        "price": "$19",
        "period": "/ mo",
        "description": "Per editor",
        "featured": true,
        "features": [
          { "feature": "Everything in Free" },
          { "feature": "Unlimited cloud storage" },
          { "feature": "Priority support" },
          { "feature": "Custom reports" },
          { "feature": "Advanced security" }
        ],
        "links": [
          {
            "link": {
              "type": "custom",
              "newTab": false,
              "url": "/admin",
              "label": "Get started",
              "appearance": "default"
            }
          }
        ]
      },
      {
        "name": "Startup",
        "price": "$29",
        "period": "/ mo",
        "description": "Per editor",
        "featured": false,
        "features": [
          { "feature": "Everything in Pro" },
          { "feature": "Dedicated success manager" },
          { "feature": "SSO and audit logs" }
        ],
        "links": [
          {
            "link": {
              "type": "custom",
              "newTab": false,
              "url": "/admin",
              "label": "Get started",
              "appearance": "outline"
            }
          }
        ]
      }
    ]
  }
}
