{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "content-list-columns",
  "version": "0.1.0",
  "title": "Content List Columns",
  "description": "A serif-headed content section with a two-column labeled-term list, installed as a wired Payload block.",
  "registryItemName": "content-list-columns",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/ContentListColumns/config.ts",
    "src/blocks/ContentListColumns/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "ContentListColumnsBlock",
      "importPath": "@/blocks/ContentListColumns/Component",
      "blockSlug": "contentListColumns"
    },
    {
      "kind": "pagesLayout",
      "importName": "ContentListColumns",
      "importPath": "../../blocks/ContentListColumns/config",
      "blockName": "ContentListColumns"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Serif heading above a two-column list of labeled-term paragraphs."
  },
  "sampleContent": {
    "blockType": "contentListColumns",
    "eyebrow": "What you get",
    "title": "Create content with AI assistance.",
    "items": [
      {
        "term": "Generate ideas",
        "description": "Spark creativity with AI-powered content suggestions and inspiration."
      },
      {
        "term": "Improve writing",
        "description": "Enhance your text with smart editing suggestions and style refinements."
      }
    ]
  }
}
