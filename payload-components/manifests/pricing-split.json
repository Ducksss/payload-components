{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "pricing-split",
  "version": "0.1.0",
  "title": "Pricing Split",
  "description": "A two-plan split pricing layout — a compact entry plan beside an expanded featured plan — installed as a wired Payload block.",
  "registryItemName": "pricing-split",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/pricingFields.ts",
    "src/blocks/PricingSplit/config.ts",
    "src/blocks/PricingSplit/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "PricingSplitBlock",
      "importPath": "@/blocks/PricingSplit/Component",
      "blockSlug": "pricingSplit"
    },
    {
      "kind": "pagesLayout",
      "importName": "PricingSplit",
      "importPath": "../../blocks/PricingSplit/config",
      "blockName": "PricingSplit"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "A compact entry plan on the left and an expanded featured plan on the right."
  },
  "sampleContent": {
    "blockType": "pricingSplit",
    "eyebrow": "Pricing",
    "title": "Pricing that scales with your team.",
    "description": "Start on the entry plan and unlock the full platform when you are ready.",
    "plans": [
      {
        "name": "Free",
        "price": "$0",
        "period": "/ mo",
        "description": "Per editor",
        "featured": false,
        "features": [
          { "feature": "Basic analytics dashboard" },
          { "feature": "5GB cloud storage" },
          { "feature": "Email and chat support" }
        ],
        "links": [
          {
            "link": {
              "type": "custom",
              "newTab": false,
              "url": "/admin",
              "label": "Get started",
              "appearance": "outline"
            }
          }
        ]
      },
      {
        "name": "Pro",
        "price": "$19",
        "period": "/ mo",
        "description": "Everything in Free, plus the tools growing teams need.",
        "featured": true,
        "features": [
          { "feature": "Unlimited cloud storage" },
          { "feature": "Priority support" },
          { "feature": "Access to community forum" },
          { "feature": "Custom reports" },
          { "feature": "Advanced security" },
          { "feature": "Single sign-on" }
        ],
        "links": [
          {
            "link": {
              "type": "custom",
              "newTab": false,
              "url": "/admin",
              "label": "Get started",
              "appearance": "default"
            }
          }
        ]
      }
    ]
  }
}
