{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "logo-cloud-inline",
  "version": "0.1.0",
  "title": "Logo Cloud Inline",
  "description": "A compact label-over-logos strip for editable trust logos, installed as a wired Payload block.",
  "registryItemName": "logo-cloud-inline",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/logoCloudFields.ts",
    "src/blocks/LogoCloudInline/config.ts",
    "src/blocks/LogoCloudInline/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "LogoCloudInlineBlock",
      "importPath": "@/blocks/LogoCloudInline/Component",
      "blockSlug": "logoCloudInline"
    },
    {
      "kind": "pagesLayout",
      "importName": "LogoCloudInline",
      "importPath": "../../blocks/LogoCloudInline/config",
      "blockName": "LogoCloudInline"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Muted label with a wrapping row of editable logos beneath it."
  },
  "sampleContent": {
    "blockType": "logoCloudInline",
    "heading": "Trusted by teams at:",
    "logos": [
      { "name": "Northwind" },
      { "name": "Initech" },
      { "name": "Umbra" },
      { "name": "Globex" }
    ]
  }
}
