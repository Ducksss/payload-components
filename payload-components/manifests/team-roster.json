{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "team-roster",
  "version": "0.1.0",
  "title": "Team Roster",
  "description": "A team section that groups members into titled departments, each a grid of avatars with name and role, installed as a wired Payload block.",
  "registryItemName": "team-roster",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/teamFields.ts",
    "src/blocks/TeamRoster/config.ts",
    "src/blocks/TeamRoster/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "TeamRosterBlock",
      "importPath": "@/blocks/TeamRoster/Component",
      "blockSlug": "teamRoster"
    },
    {
      "kind": "pagesLayout",
      "importName": "TeamRoster",
      "importPath": "../../blocks/TeamRoster/config",
      "blockName": "TeamRoster"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Heading above department-grouped sections, each a grid of member avatars with name and role."
  },
  "sampleContent": {
    "blockType": "teamRoster",
    "eyebrow": "Our team",
    "title": "The people building Payload Components.",
    "groups": [
      {
        "label": "Leadership",
        "members": [
          { "name": "Ada Lovelace", "role": "Co-Founder & CEO" },
          { "name": "Alan Turing", "role": "Co-Founder & CTO" },
          { "name": "Grace Hopper", "role": "Chief Operating Officer" }
        ]
      },
      {
        "label": "Engineering",
        "members": [
          { "name": "Linus Torvalds", "role": "Principal Engineer" },
          { "name": "Margaret Hamilton", "role": "Staff Engineer" },
          { "name": "Dennis Ritchie", "role": "Backend Lead" }
        ]
      }
    ]
  }
}
