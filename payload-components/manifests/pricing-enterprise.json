{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "pricing-enterprise",
  "version": "0.1.0",
  "title": "Pricing Enterprise",
  "description": "A single wide enterprise pricing panel with an included-features list and an editable wall of trust logos, installed as a wired Payload block.",
  "registryItemName": "pricing-enterprise",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/pricingFields.ts",
    "src/blocks/PricingEnterprise/config.ts",
    "src/blocks/PricingEnterprise/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "PricingEnterpriseBlock",
      "importPath": "@/blocks/PricingEnterprise/Component",
      "blockSlug": "pricingEnterprise"
    },
    {
      "kind": "pagesLayout",
      "importName": "PricingEnterprise",
      "importPath": "../../blocks/PricingEnterprise/config",
      "blockName": "PricingEnterprise"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "One wide enterprise panel: price and CTA beside an included-features list and trust logos."
  },
  "sampleContent": {
    "blockType": "pricingEnterprise",
    "eyebrow": "Enterprise",
    "title": "Start managing your company smarter today.",
    "description": "One plan for teams of any size, with every feature included.",
    "plans": [
      {
        "name": "Suite Enterprise",
        "price": "$234",
        "period": "/ mo",
        "description": "For your company of any size",
        "featured": false,
        "features": [
          { "feature": "Security and compliance" },
          { "feature": "Unlimited storage" },
          { "feature": "Payments and search engine" },
          { "feature": "Access to all components" }
        ],
        "links": [
          {
            "link": {
              "type": "custom",
              "newTab": false,
              "url": "/admin",
              "label": "Get started",
              "appearance": "default"
            }
          }
        ]
      }
    ],
    "logos": [
      { "name": "Northwind" },
      { "name": "Initech" },
      { "name": "Globex" }
    ]
  }
}
