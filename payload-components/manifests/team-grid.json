{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "team-grid",
  "version": "0.1.0",
  "title": "Team Grid",
  "description": "A team section with a heading, intro paragraph, and a responsive grid of large member photo cards that reveal role and link on hover, installed as a wired Payload block.",
  "registryItemName": "team-grid",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/teamFields.ts",
    "src/blocks/TeamGrid/config.ts",
    "src/blocks/TeamGrid/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "TeamGridBlock",
      "importPath": "@/blocks/TeamGrid/Component",
      "blockSlug": "teamGrid"
    },
    {
      "kind": "pagesLayout",
      "importName": "TeamGrid",
      "importPath": "../../blocks/TeamGrid/config",
      "blockName": "TeamGrid"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Heading and intro above a responsive grid of large member photo cards with hover-revealed roles."
  },
  "sampleContent": {
    "blockType": "teamGrid",
    "eyebrow": "Team",
    "title": "Our dream team.",
    "description": "A small, senior team shipping the platform that product teams open every day.",
    "members": [
      { "name": "Henry Lee", "role": "UX Engineer" },
      { "name": "Isabella Garcia", "role": "Sales Manager" },
      { "name": "Liam Brown", "role": "Founder & CEO" },
      { "name": "Olivia Miller", "role": "Visual Designer" },
      { "name": "Ava Williams", "role": "Interaction Designer" },
      { "name": "Elijah Jones", "role": "Co-Founder & CTO" }
    ]
  }
}
