{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "call-to-action-boxed",
  "version": "0.1.0",
  "title": "Call To Action Boxed",
  "description": "A boxed call-to-action Payload block: heading, supporting copy, and CTA links inside a nested panel.",
  "registryItemName": "call-to-action-boxed",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/blocks/shared/callToActionFields.ts",
    "src/blocks/CallToActionBoxed/config.ts",
    "src/blocks/CallToActionBoxed/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "CallToActionBoxedBlock",
      "importPath": "@/blocks/CallToActionBoxed/Component",
      "blockSlug": "callToActionBoxed"
    },
    {
      "kind": "pagesLayout",
      "importName": "CallToActionBoxed",
      "importPath": "../../blocks/CallToActionBoxed/config",
      "blockName": "CallToActionBoxed"
    }
  ],
  "recovery": {
    "patchedFiles": ["src/blocks/RenderBlocks.tsx", "src/collections/Pages/index.ts"]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Boxed call-to-action: heading, copy, and CTA buttons inside a nested panel."
  },
  "sampleContent": {
    "blockType": "callToActionBoxed",
    "title": "Bring your team to Acme.",
    "description": "A framed, high-emphasis call to action for the end of a landing page — the box draws the eye to the next step.",
    "links": [
      {
        "link": {
          "type": "custom",
          "newTab": false,
          "url": "/signup",
          "label": "Create an account",
          "appearance": "default"
        }
      },
      {
        "link": {
          "type": "custom",
          "newTab": false,
          "url": "/contact",
          "label": "Talk to sales",
          "appearance": "outline"
        }
      }
    ]
  }
}
