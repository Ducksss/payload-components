{
  "$schema": "../../schema/poc-manifest.schema.json",
  "name": "example-basic",
  "version": "0.1.0",
  "title": "Example Basic",
  "description": "Replace this example metadata with the real component summary.",
  "registryItemName": "example-basic",
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "files": [
    "src/blocks/ExampleBasic/config.ts",
    "src/blocks/ExampleBasic/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "ExampleBasicBlock",
      "importPath": "@/blocks/ExampleBasic/Component",
      "blockSlug": "exampleBasic"
    },
    {
      "kind": "pagesLayout",
      "importName": "ExampleBasic",
      "importPath": "../../blocks/ExampleBasic/config",
      "blockName": "ExampleBasic"
    }
  ],
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Replace this summary with the editor-facing preview copy."
  },
  "sampleContent": {
    "blockType": "exampleBasic",
    "eyebrow": "Component Template",
    "title": "Replace this title with your component's primary headline.",
    "description": "Use sample content that makes the block easy to validate in Payload admin and on the frontend.",
    "links": [
      {
        "link": {
          "type": "custom",
          "newTab": false,
          "url": "/",
          "label": "Primary action",
          "appearance": "default"
        }
      }
    ]
  },
  "recovery": {
    "patchedFiles": [
      "src/blocks/RenderBlocks.tsx",
      "src/collections/Pages/index.ts"
    ]
  }
}
