{
  "name": "payload-components",
  "version": "1.0.0",
  "description": "Fumadocs-powered docs and registry tooling for installable Payload CMS components.",
  "license": "MIT",
  "homepage": "https://payload-components.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ducksss/payload-components.git"
  },
  "bugs": {
    "url": "https://github.com/Ducksss/payload-components/issues"
  },
  "type": "module",
  "bin": {
    "payload-components": "./bin/payload-components.mjs"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload-components": "node ./bin/payload-components.mjs",
    "prebuild": "pnpm source:build && pnpm registry:build",
    "registry:build": "cross-env NODE_OPTIONS=--no-deprecation pnpm dlx shadcn@4.7.0 build payload-components/registry.json --output public/r --cwd .",
    "registry:check": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/payload-components/check-public-registry.ts",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "showcase:capture": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/showcase/capture.ts",
    "source:build": "cross-env NODE_OPTIONS=--no-deprecation fumadocs-mdx",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:fresh": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/payload-components/smoke/fresh-payload-repo.ts",
    "test:install": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts tests/int/payload-components.int.spec.ts tests/int/payload-components-registry.int.spec.ts tests/int/payload-components-add-command.int.spec.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:registry": "pnpm registry:check",
    "test:release": "pnpm lint && pnpm source:build && pnpm exec tsc --noEmit && pnpm test:registry && pnpm run test:int && pnpm run test:e2e && pnpm build"
  },
  "dependencies": {
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "17.4.2",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.10",
    "fumadocs-ui": "16.9.3",
    "geist": "^1.3.0",
    "lucide-react": "0.563.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "semver": "^7.7.4",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.22.4",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify": "3.4.5",
      "drizzle-orm": "0.45.2",
      "esbuild": "0.28.1",
      "fast-uri": "3.1.2",
      "postcss": "8.5.14",
      "uuid": "11.1.1"
    }
  }
}
