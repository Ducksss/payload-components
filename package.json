{
  "name": "payload-components",
  "version": "1.0.0",
  "description": "Registry-backed block kits and a Next.js marketing site for Payload CMS v3 projects.",
  "license": "MIT",
  "homepage": "https://payload-components.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ducksss/payload-components.git"
  },
  "bugs": {
    "url": "https://github.com/Ducksss/payload-components/issues"
  },
  "type": "module",
  "bin": {
    "payload-kit": "./bin/payload-kit.mjs"
  },
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "payload-kit": "node ./bin/payload-kit.mjs",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "prebuild": "pnpm registry:build",
    "registry:build": "cross-env NODE_OPTIONS=--no-deprecation pnpm dlx shadcn@4.7.0 build payload-kits/registry.json --output public/r --cwd .",
    "registry:check": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/payload-kit/check-public-registry.ts",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:fresh": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/payload-kit/smoke/fresh-payload-repo.ts",
    "test:install": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts tests/int/payload-kit.int.spec.ts tests/int/payload-kit-registry.int.spec.ts tests/int/payload-kit-add-command.int.spec.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "test:registry": "pnpm registry:check",
    "test:shadcn": "cross-env NODE_OPTIONS=--no-deprecation tsx tools/payload-kit/smoke/fresh-payload-repo.ts --direct-only",
    "test:release": "pnpm lint && pnpm exec tsc --noEmit && pnpm test:registry && pnpm test:shadcn && pnpm run test:int && pnpm run test:e2e && pnpm build && pnpm test:fresh"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-vercel-postgres": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ajv": "^8.18.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-ui": "^16.9.0",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "16.2.6",
    "next-sitemap": "^4.2.3",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "semver": "^7.7.4",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "postcss": "^8.5.14",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ],
    "overrides": {
      "dompurify": "3.4.5",
      "drizzle-orm": "0.45.2",
      "esbuild": "0.27.7",
      "fast-uri": "3.1.2",
      "postcss": "8.5.14",
      "uuid": "11.1.1"
    }
  }
}
