{
  "$schema": "../schema/poc-manifest.schema.json",
  "name": "hero-basic",
  "version": "0.1.0",
  "title": "Hero Basic",
  "description": "A golden-kit Payload block used to prove that shadcn-compatible registry installs can be wrapped with Payload-specific wiring.",
  "installMode": "payload-kit-required",
  "registryItemName": "hero-basic",
  "dependencies": {},
  "peerDependencies": {
    "next": "^15.0.0 || ^16.0.0",
    "payload": "^3.0.0"
  },
  "supportedTargets": ["payload-website-starter"],
  "supports": {
    "payloadMajors": [3],
    "nextMajors": [15, 16]
  },
  "files": [
    "src/utilities/ui.ts",
    "src/blocks/HeroBasic/config.ts",
    "src/blocks/HeroBasic/Component.tsx"
  ],
  "payloadFragments": [
    {
      "kind": "renderBlocks",
      "importName": "HeroBasicBlock",
      "importPath": "@/blocks/HeroBasic/Component",
      "blockSlug": "heroBasic"
    },
    {
      "kind": "pagesLayout",
      "importName": "HeroBasic",
      "importPath": "../../blocks/HeroBasic/config",
      "blockName": "HeroBasic"
    }
  ],
  "recovery": {
    "patchedFiles": [
      "src/blocks/RenderBlocks.tsx",
      "src/collections/Pages/index.ts"
    ]
  },
  "postInstall": ["generate:types", "generate:importmap"],
  "preview": {
    "summary": "Headline-led hero block with CTA links and proof badges."
  },
  "sampleContent": {
    "blockType": "heroBasic",
    "eyebrow": "Payload Kits POC",
    "title": "Install a Payload-native hero block through a real registry flow.",
    "description": "This golden kit exists to prove that shadcn-compatible registry resources can be installed, registered in Payload, and regenerated cleanly in a live project.",
    "links": [
      {
        "link": {
          "type": "custom",
          "newTab": false,
          "url": "/admin",
          "label": "Open the CMS",
          "appearance": "default"
        }
      },
      {
        "link": {
          "type": "custom",
          "newTab": false,
          "url": "/",
          "label": "Return home",
          "appearance": "outline"
        }
      }
    ],
    "proofItems": [
      { "label": "Registry-backed install" },
      { "label": "Payload layout wiring" },
      { "label": "Type-safe regeneration" }
    ]
  }
}
